rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "banmekeifeoluwa@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && request.resource.data.role == 'student';
      allow update: if isOwner(userId) || isAdmin();
      
      match /private/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /broadcasts/{broadcastId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /pending_questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['votes', 'status']);
      allow delete: if isAdmin();
    }
    
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    match /hosted_tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerified == true;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.hostId;
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.hostId);
    }

    match /test_results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false; // Results shouldn't be updated
      allow delete: if isAdmin();
    }
  }
}
