rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection Test Document (Public Read Only)
    match /_internal_/connection_test {
      allow read: if true;
    }

    // Phase 3 Primitives & Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email_verified == true && (
        request.auth.token.get('email', '') == 'banmekeifeoluwa@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Pillar 2: Validation Blueprints
    function isValidResource(data) {
      return data.keys().hasAll(['title', 'type', 'url', 'course', 'uploadedBy', 'userId', 'department', 'level', 'category', 'timestamp', 'likes', 'dislikes', 'downloads', 'uploaderVerified', 'validated', 'qualityScore']) &&
             data.title is string && data.title.size() <= 100 &&
             data.url is string && data.url.size() <= 1000 &&
             data.course is string && data.course.size() <= 20 &&
             data.department is string && data.department.size() <= 100 &&
             data.userId == request.auth.uid &&
             data.timestamp == request.time &&
             data.likes == 0 && data.dislikes == 0 && data.downloads == 0;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.xp >= 0 || isAdmin());
      
      allow create: if isOwner(userId) && 
                      (incoming().role == 'student' || incoming().role == 'guest') && 
                      incoming().isVerified == false &&
                      incoming().createdAt == request.time;
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: Standard Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'matricNumber', 'faculty', 'department', 'level', 'xp', 'currentStreak', 'lastActiveDate', 'dailyTokenCount', 'lastTokenReset', 'email', 'isShana', 'cbtTimeSpent', 'highScoreCount', 'shanaPeriodStart', 'isGuest', 'uid', 'followedUploaders'])) ||
        // Action: Admin Override
        isAdmin()
      );
    }

    // 2. Resources Collection
    match /resources/{resourceId} {
      // Public Read as requested
      allow read: if true;
      
      // Pillar 3: Path Variable Hardening
      allow get: if isValidId(resourceId);
      
      // Keep creation for verified students but restrict management to Admin
      allow create: if isSignedIn() && isValidId(resourceId) && isValidResource(incoming()) && (isVerified() || isAdmin());
      
      // Restrict all updates and deletes to Admin as strictly requested
      allow update: if (isAdmin() && isValidId(resourceId)) || (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['uploadedBy']));
      allow delete: if isAdmin() && isValidId(resourceId);
    }
    
    // 2.1 Reports Collection
    function isValidReport(data) {
      return data.keys().hasAll(['resourceId', 'resourceTitle', 'reason', 'reportedBy', 'reporterName', 'timestamp', 'status']) &&
             data.resourceId is string && data.resourceId.size() <= 128 &&
             data.reason is string && data.reason.size() <= 500 &&
             data.reportedBy == request.auth.uid &&
             data.timestamp == request.time &&
             data.status == "pending";
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidReport(incoming()) && 
                      exists(/databases/$(database)/documents/resources/$(incoming().resourceId));
      allow update: if isAdmin() || (isOwner(existing().reportedBy) && incoming().diff(existing()).affectedKeys().hasOnly(['reporterName']));
      allow delete: if isAdmin();
    }

    // 3. Community Reviews
    match /community_reviews/{reviewId} {
      allow read: if isAdmin() || resource.data.get('text', null) != null;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().text.size() <= 1000;
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['userName']);
      allow delete: if isAdmin();
    }

    // 4. CBT Related
    match /courses/{courseId} {
      allow read: if isAdmin() || resource.data.get('code', null) != null;
      allow write: if isAdmin();
    }
    
    match /pending_questions/{id} {
      allow read: if isSignedIn() && (resource.data.status == "pending" || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['authorName']));
      allow delete: if isAdmin();
    }

    match /hosted_tests/{id} {
      allow read: if isSignedIn() && (resource.data.status == "active" || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /test_results/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['userName']);
    }

    // 5. User CGPA Data
    match /user_cgpa/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 6. Notifications & Alerts
    match /notifications/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
    }

    match /security_alerts/{id} {
      allow read: if isAdmin();
      allow create: if true; // System creates these
    }

    match /payment_verifications/{id} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // 9. Admin Collections
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
